{
  "manifest_version": 3,
  "name": "AI Upload Blocker",
  "version": "1.4.0",
  "description": "Blocks file uploads to AI services on managed endpoints. Browsing permitted.",

  "permissions": [
    "declarativeNetRequest",
    "scripting"
  ],

  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "upload_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "ai-upload-blocker@internal",
      "strict_min_version": "128.0"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
